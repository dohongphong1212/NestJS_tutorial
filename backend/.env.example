# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit file `.env`.

# PostgreSQL (Docker: container nest_postgres, DB nest_auth)
DATABASE_URL="postgresql://postgres:password@localhost:5432/nest_auth?sslmode=disable"

# JWT secrets — mỗi cái là một chuỗi ngẫu nhiên >= 32 ký tự, KHÁC nhau.
# Tạo nhanh: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="thay-bang-chuoi-ngau-nhien-it-nhat-32-ky-tu"
JWT_REFRESH_SECRET="thay-bang-chuoi-ngau-nhien-khac-it-nhat-32-ky-tu"

# (Tuỳ chọn) origin của frontend cho CORS
FRONTEND_URL="http://localhost:3001"
